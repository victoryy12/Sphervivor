extends RigidBody3D
@export var rolling_force: float = 100.0
@export var jump_force: float = 150.0
@export var mouse_sensitivity: float = 0.0022
@export var pitch_limit_deg: float = 65.0
var yaw: float = 0.0
var pitch: float = 0.0
@onready var camera_rig: Node3D = $CameraRig
@onready var camera_pivot: Node3D = $CameraRig/PitchPivot
@onready var touching_floor: RayCast3D = $touchingFloor
func _ready() -> void:
	camera_rig.top_level = true
	touching_floor.top_level = true
	Input.set_mouse_mode(Input.MOUSE_MODE_CAPTURED)
func _unhandled_input(event: InputEvent) -> void:
	if event is InputEventKey and event.pressed and event.keycode == KEY_ESCAPE:
		if Input.get_mouse_mode() == Input.MOUSE_MODE_CAPTURED:
			Input.set_mouse_mode(Input.MOUSE_MODE_VISIBLE)
		else:
			Input.set_mouse_mode(Input.MOUSE_MODE_CAPTURED)
	if event is InputEventMouseMotion and Input.get_mouse_mode() == Input.MOUSE_MODE_CAPTURED:
		# Yaw
		yaw -= event.relative.x * mouse_sensitivity
		camera_rig.rotation.y = yaw
		# Pitch
		var limit := deg_to_rad(pitch_limit_deg)
		pitch = clamp(pitch - event.relative.y * mouse_sensitivity, -limit, limit)
		camera_pivot.rotation.x = pitch
func _physics_process(delta: float) -> void:
	# Keep rig/raycast following the ball
	camera_rig.global_position = global_position
	touching_floor.global_position = global_position
	# Death plane
	var death_barrier_depth := -25.0
	if global_position.y < death_barrier_depth:
		get_tree().reload_current_scene()
		return
	var on_floor := touching_floor.is_colliding()
	# Camera-relative movement input
	var input_x := Input.get_action_strength("right") - Input.get_action_strength("left")
	var input_z := Input.get_action_strength("down") - Input.get_action_strength("up")
	if on_floor and (input_x != 0.0 or input_z != 0.0):
		var forward := -camera_rig.global_basis.z
		var right := camera_rig.global_basis.x
		forward.y = 0.0
		right.y = 0.0
		forward = forward.normalized()
		right = right.normalized()
		var move_dir := (right * input_x + forward * input_z).normalized()
		# Torque axis to roll sphere toward move_dir
		var torque_axis := Vector3.UP.cross(move_dir).normalized()
		apply_torque(torque_axis * rolling_force)
	# Jump
	if Input.is_action_just_pressed("jump") and on_floor:
		apply_central_impulse(Vector3.UP * jump_force)
	# Slam
	if Input.is_action_pressed("slam") and not on_floor:
		angular_velocity.y -= rolling_force * delta
		apply_central_force(Vector3.DOWN * 10000.0)
